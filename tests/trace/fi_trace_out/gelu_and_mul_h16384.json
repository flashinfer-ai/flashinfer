  "reference": "@torch.no_grad()\ndef _gelu_and_mul_reference(input):\n    \"\"\"Fused GeLU (exact) + Mul: gelu(x[:H]) * x[H:]\"\"\"\n    half = input.shape[-1] // 2\n    return F.gelu(input[..., :half]) * input[..., half:]\n"
