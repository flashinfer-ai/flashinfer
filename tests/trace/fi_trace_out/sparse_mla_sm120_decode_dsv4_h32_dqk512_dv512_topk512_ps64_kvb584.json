{
  "name": "sparse_mla_sm120_decode_dsv4_h32_dqk512_dv512_topk512_ps64_kvb584",
  "description": "Sparse-MLA paged decode (DSv4 standalone kernel) on SM120 with optional dual-cache support and AutoTuner-driven chunks_per_block tactic selection.",
  "op_type": "sparse_mla_decode_dsv4_sm120",
  "tags": [
    "fi_api:flashinfer.mla._sparse_mla_sm120.sparse_mla_sm120_decode_dsv4",
    "status:wip",
    "sparse:topk",
    "backend:sm120",
    "model:dsv4"
  ],
  "axes": {
    "num_tokens": {
      "type": "var",
      "description": "Number of query tokens."
    },
    "num_heads": {
      "type": "const",
      "value": 32,
      "description": "Number of query heads after TP split."
    },
    "head_dim_qk": {
      "type": "const",
      "value": 512,
      "description": "Query head dim. 512 for the DSv4 family."
    },
    "head_dim_v": {
      "type": "const",
      "value": 512,
      "description": "Value head dim. 512."
    },
    "topk": {
      "type": "const",
      "value": 512,
      "description": "Number of top-K paged slots per query token ({128, 512, 1024})."
    },
    "page_block_size": {
      "type": "const",
      "value": 64,
      "description": "KV cache page block size (64)."
    },
    "num_pages": {
      "type": "var",
      "description": "Total allocated pages in the KV cache."
    },
    "extra_num_pages": {
      "type": "var",
      "description": "Pages in the optional secondary KV cache (dual-cache mode)."
    },
    "extra_topk": {
      "type": "const",
      "description": "Top-K width for the secondary cache."
    },
    "extra_page_block_size": {
      "type": "const",
      "description": "Page block size of the secondary cache."
    },
    "kv_bytes_per_token": {
      "type": "const",
      "value": 584,
      "description": "Byte-packed FP8 FOOTER stride (584 = 448 nope + 128 rope + 8 scales)."
    },
    "num_splits": {
      "type": "var",
      "description": "ceil(topk / 64) + ceil(extra_topk / 64); mid_out splits."
    }
  },
  "constraints": [
    "indices.shape[0] == num_tokens",
    "indices.shape[-1] == topk",
    "kv_cache.shape[1] == page_block_size",
    "head_dim_qk == 512",
    "head_dim_v == 512",
    "topk in (128, 512, 1024)",
    "extra_indices.shape[0] == num_tokens",
    "extra_indices.shape[-1] == extra_topk",
    "extra_kv_cache.shape[1] == extra_page_block_size"
  ],
  "inputs": {
    "q": {
      "shape": [
        "num_tokens",
        "num_heads",
        "head_dim_qk"
      ],
      "dtype": "bfloat16",
      "description": "Query tensor, dtype bf16."
    },
    "kv_cache": {
      "shape": [
        "num_pages",
        "page_block_size",
        "1",
        "kv_bytes_per_token"
      ],
      "dtype": "uint8",
      "description": "Paged main KV cache, FP8 FOOTER layout."
    },
    "indices": {
      "shape": [
        "num_tokens",
        "topk"
      ],
      "dtype": "int32",
      "description": "Paged slot IDs. -1 marks invalid / out-of-window."
    },
    "mid_out": {
      "shape": [
        "num_tokens",
        "num_heads",
        "num_splits",
        "head_dim_v"
      ],
      "dtype": "bfloat16",
      "description": "Per-split partial outputs (bf16 scratch)."
    },
    "mid_lse": {
      "shape": [
        "num_tokens",
        "num_heads",
        "num_splits"
      ],
      "dtype": "float32",
      "description": "Per-split LSE (float32 scratch)."
    },
    "output": {
      "shape": [
        "num_tokens",
        "num_heads",
        "head_dim_v"
      ],
      "dtype": "bfloat16",
      "description": "In-place output buffer."
    },
    "out_lse": {
      "shape": [
        "num_tokens",
        "num_heads"
      ],
      "dtype": "float32",
      "description": "In-place log-sum-exp (2-based; merges attn_sink when present)."
    },
    "sm_scale": {
      "shape": null,
      "dtype": "float32",
      "description": "Softmax scale, typically 1/sqrt(head_dim_qk)."
    },
    "topk_length": {
      "shape": [
        "num_tokens"
      ],
      "dtype": "unknown",
      "optional": true,
      "description": "Effective top-k length per query token."
    },
    "extra_kv_cache": {
      "shape": [
        "extra_num_pages",
        "extra_page_block_size",
        "1",
        "kv_bytes_per_token"
      ],
      "dtype": "unknown",
      "optional": true,
      "description": "Optional secondary KV cache, FP8 FOOTER layout."
    },
    "extra_indices": {
      "shape": [
        "num_tokens",
        "extra_topk"
      ],
      "dtype": "unknown",
      "optional": true,
      "description": "Paged slot IDs for the secondary cache."
    },
    "extra_topk_length": {
      "shape": [
        "num_tokens"
      ],
      "dtype": "unknown",
      "optional": true,
      "description": "Effective top-k length per query token for the secondary cache."
    },
    "attn_sink": {
      "shape": [
        "num_heads"
      ],
      "dtype": "unknown",
      "optional": true,
      "description": "Per-head learnable bias added pre-softmax. FlashMLA V4 convention: output *= sigmoid(lse - sink), lse' = log(exp(lse) + exp(sink))."
    }
  },
  "outputs": {
    "output": {
      "shape": [
        "num_tokens",
        "num_heads",
        "head_dim_v"
      ],
      "dtype": "bfloat16",
      "description": "Attention output (also mutated in place above)."
    },
    "out_lse": {
      "shape": [
        "num_tokens",
        "num_heads"
      ],
      "dtype": "float32",
      "description": "The 2-based log-sum-exp of attention logits (sink-merged)."
    }
  }
}
